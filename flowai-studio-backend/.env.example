# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL="file:./dev.db"

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# AI Configuration
LLM_PROVIDER=ark
LLM_API_KEY=your-ark-api-key-here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=your-ark-endpoint-id-or-open-model

# Ark Configuration
ARK_API_KEY=your-ark-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=your-ark-endpoint-id-or-open-model
ARK_EMBEDDING_MODEL=doubao-embedding-text-240715

# RAG Embedding Configuration
EMBEDDING_PROVIDER=ark
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
EMBEDDING_MODEL=doubao-embedding-text-240715
RAG_TOP_K=2
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_MAX_CONTEXT_CHARS=2500
CODE_RAG_MAX_CONTEXT_CHARS=9000
CHAT_HISTORY_LIMIT=4

# Qwen Configuration
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v3
